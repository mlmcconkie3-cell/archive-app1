<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Archive</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --text:rgba(255,255,255,0.95);
  --text2:rgba(255,255,255,0.68);
  --text3:rgba(255,255,255,0.42);
  --gold:rgba(255,205,80,0.95);
  --green:rgba(90,220,110,0.95);
  --r:16px;--rs:10px;
  --gb:rgba(255,255,255,0.15);
  --gb2:rgba(255,255,255,0.22);
  --gborder:rgba(255,255,255,0.32);
  --gshadow:0 8px 32px rgba(0,0,0,0.2),inset 0 1px 0 rgba(255,255,255,0.4);
}
body{font-family:'DM Sans',sans-serif;min-height:100vh;color:var(--text);overflow-x:hidden;background:#1a2a10}
.hidden{display:none!important}

.bg{position:fixed;top:0;left:0;width:100%;height:100%;background-image:url("data:image/jpeg;base64,");background-size:cover;background-position:center;z-index:0}
.bg-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.08);z-index:1}

/* GLASS */
.glass{
  background:var(--gb);
  backdrop-filter:blur(28px) saturate(1.9);
  -webkit-backdrop-filter:blur(28px) saturate(1.9);
  border:1px solid var(--gborder);
  box-shadow:var(--gshadow);
}

/* LOADING */
#loading{position:relative;z-index:10;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px}
.logo-big{font-family:'Bebas Neue',sans-serif;font-size:72px;letter-spacing:-1px;color:#000;text-shadow:0 2px 30px rgba(0,0,0,0.15);line-height:1}
.logo-sub-sm{font-size:11px;letter-spacing:0.22em;text-transform:uppercase;color:rgba(0,0,0,0.55);font-weight:400}
.lbar{width:64px;height:1.5px;background:rgba(0,0,0,0.15);border-radius:2px;overflow:hidden;margin-top:10px}
.lfill{height:100%;background:rgba(0,0,0,0.45);animation:lf 1.6s ease-out forwards}
@keyframes lf{from{width:0}to{width:100%}}

/* AUTH */
.auth{position:relative;z-index:10;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px}
.auth-card{width:100%;max-width:390px}
.auth-logo{text-align:center;margin-bottom:28px}
.auth-logo h1{font-family:'Bebas Neue',sans-serif;font-size:62px;letter-spacing:-1px;color:#000;text-shadow:0 1px 12px rgba(0,0,0,0.12);line-height:1}
.auth-logo p{font-size:11px;color:rgba(0,0,0,0.5);letter-spacing:0.18em;text-transform:uppercase;margin-top:2px}
.auth-box{
  border-radius:var(--r);padding:28px;
  background:rgba(255,255,255,0.18);
  backdrop-filter:blur(40px) saturate(2);
  -webkit-backdrop-filter:blur(40px) saturate(2);
  border:1px solid rgba(255,255,255,0.45);
  box-shadow:0 20px 60px rgba(0,0,0,0.18),inset 0 1px 0 rgba(255,255,255,0.55);
}
.auth-box h2{font-size:18px;font-weight:400;margin-bottom:3px;color:#000}
.auth-box .sub{font-size:13px;color:rgba(0,0,0,0.5);margin-bottom:22px}
.field{margin-bottom:13px}
.field label{display:block;font-size:10px;color:rgba(0,0,0,0.45);margin-bottom:5px;text-transform:uppercase;letter-spacing:0.1em}
.field input{
  width:100%;padding:11px 13px;
  background:rgba(255,255,255,0.3);
  backdrop-filter:blur(10px);
  border:1px solid rgba(255,255,255,0.5);
  border-radius:var(--rs);
  color:#000;font-size:14px;font-family:'DM Sans',sans-serif;
  transition:all 0.2s;
  box-shadow:inset 0 1px 0 rgba(255,255,255,0.4);
}
.field input:focus{outline:none;border-color:rgba(255,255,255,0.8);background:rgba(255,255,255,0.42);box-shadow:0 0 0 3px rgba(255,255,255,0.18),inset 0 1px 0 rgba(255,255,255,0.5)}
.field input::placeholder{color:rgba(0,0,0,0.28)}
.btn-p{
  width:100%;padding:12px;
  background:rgba(0,0,0,0.55);
  border:1px solid rgba(0,0,0,0.2);
  border-radius:var(--rs);color:#fff;
  font-size:14px;font-weight:500;cursor:pointer;
  font-family:'DM Sans',sans-serif;margin-top:6px;
  transition:all 0.2s;letter-spacing:0.02em;
}
.btn-p:hover{background:rgba(0,0,0,0.7)}
.btn-p:disabled{opacity:0.4;cursor:not-allowed}
.btn-o{
  width:100%;padding:10px;
  background:rgba(255,255,255,0.18);
  border:1px solid rgba(255,255,255,0.35);
  border-radius:var(--rs);color:rgba(0,0,0,0.65);
  font-size:13px;cursor:pointer;
  font-family:'DM Sans',sans-serif;transition:all 0.2s;margin-top:8px;
}
.btn-o:hover{background:rgba(255,255,255,0.3);color:#000}
.divider{display:flex;align-items:center;gap:10px;margin:14px 0;color:rgba(0,0,0,0.3);font-size:12px}
.divider::before,.divider::after{content:'';flex:1;height:1px;background:rgba(0,0,0,0.12)}
.err{background:rgba(200,50,50,0.12);border:1px solid rgba(200,50,50,0.25);border-radius:var(--rs);padding:9px 13px;font-size:13px;color:rgba(180,40,40,0.9);margin-bottom:13px}
.switch{text-align:center;margin-top:16px;font-size:13px;color:rgba(0,0,0,0.5)}
.switch a{color:rgba(0,0,0,0.75);cursor:pointer;text-decoration:underline;text-underline-offset:3px}

/* APP */
.app{display:none;flex-direction:column;min-height:100vh;position:relative;z-index:10}
.topbar{
  padding:13px 18px;display:flex;align-items:center;justify-content:space-between;
  background:rgba(255,255,255,0.14);
  backdrop-filter:blur(32px) saturate(2);
  -webkit-backdrop-filter:blur(32px) saturate(2);
  border-bottom:1px solid rgba(255,255,255,0.28);
  box-shadow:inset 0 1px 0 rgba(255,255,255,0.35);
}
.topbar-logo{font-family:'Bebas Neue',sans-serif;font-size:28px;letter-spacing:-0.5px;color:#000;line-height:1}
.topbar-right{display:flex;align-items:center;gap:10px}
.av{width:30px;height:30px;border-radius:50%;background:rgba(0,0,0,0.45);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:500;color:#fff;border:1px solid rgba(255,255,255,0.3)}
.signout{font-size:12px;color:rgba(0,0,0,0.5);background:none;border:none;cursor:pointer;font-family:'DM Sans',sans-serif}
.signout:hover{color:#000}
.content{flex:1;overflow-y:auto;padding:18px}
.view{display:none}
.view.active{display:block}

/* BOTTOM NAV */
.bottom-nav{
  display:flex;
  background:rgba(255,255,255,0.14);
  backdrop-filter:blur(32px) saturate(2);
  -webkit-backdrop-filter:blur(32px) saturate(2);
  border-top:1px solid rgba(255,255,255,0.28);
  box-shadow:inset 0 1px 0 rgba(255,255,255,0.3);
}
.bn{flex:1;padding:10px 6px;display:flex;flex-direction:column;align-items:center;gap:3px;cursor:pointer;border:none;background:transparent;color:rgba(0,0,0,0.35);font-size:10px;font-family:'DM Sans',sans-serif;text-transform:uppercase;letter-spacing:0.07em;transition:color 0.15s}
.bn.active{color:rgba(0,0,0,0.85)}
.bn svg{width:19px;height:19px}

/* AI BADGE */
.ai-badge{background:rgba(80,200,100,0.14);border:1px solid rgba(80,200,100,0.3);border-radius:var(--rs);padding:8px 14px;font-size:12px;color:rgba(30,130,50,0.95);margin-bottom:14px;display:flex;align-items:center;gap:7px;backdrop-filter:blur(10px)}

/* UPLOAD */
.upzone{border:1.5px dashed rgba(0,0,0,0.2);border-radius:var(--r);padding:42px 18px;text-align:center;cursor:pointer;transition:all 0.2s;margin-bottom:16px;background:rgba(255,255,255,0.12);backdrop-filter:blur(22px);-webkit-backdrop-filter:blur(22px)}
.upzone:hover,.upzone.drag{border-color:rgba(0,0,0,0.45);background:rgba(255,255,255,0.22)}
.up-icon{width:48px;height:48px;border-radius:50%;background:rgba(0,0,0,0.1);border:1px solid rgba(0,0,0,0.15);display:flex;align-items:center;justify-content:center;margin:0 auto 13px;box-shadow:inset 0 1px 0 rgba(255,255,255,0.4)}
.upzone h3{font-size:15px;font-weight:400;margin-bottom:4px;color:#000}
.upzone p{font-size:13px;color:rgba(0,0,0,0.5)}
.demo-row{text-align:center;margin-bottom:18px}
.demo-row p{font-size:10px;color:rgba(0,0,0,0.38);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.08em}
.demo-btns{display:flex;gap:6px;justify-content:center;flex-wrap:wrap}
.db{padding:5px 12px;font-size:12px;border:1px solid rgba(0,0,0,0.18);border-radius:20px;cursor:pointer;background:rgba(255,255,255,0.2);backdrop-filter:blur(10px);color:rgba(0,0,0,0.6);font-family:'DM Sans',sans-serif;transition:all 0.15s}
.db:hover{border-color:rgba(0,0,0,0.4);background:rgba(255,255,255,0.35);color:#000}

/* ANALYZING */
.analyzing{text-align:center;padding:42px 18px;border-radius:var(--r);background:rgba(255,255,255,0.16);backdrop-filter:blur(28px);-webkit-backdrop-filter:blur(28px);border:1px solid rgba(255,255,255,0.35);box-shadow:0 8px 32px rgba(0,0,0,0.12),inset 0 1px 0 rgba(255,255,255,0.45)}
.pw{width:56px;height:56px;margin:0 auto 16px;position:relative;display:flex;align-items:center;justify-content:center}
.pr{position:absolute;width:56px;height:56px;border-radius:50%;border:1.5px solid rgba(0,0,0,0.35);animation:pr 1.4s ease-out infinite}
.pd{width:16px;height:16px;border-radius:50%;background:rgba(0,0,0,0.4)}
@keyframes pr{0%{transform:scale(0.7);opacity:1}100%{transform:scale(1.7);opacity:0}}
.analyzing h3{font-size:15px;font-weight:400;margin-bottom:4px;color:#000}
.analyzing p{font-size:13px;color:rgba(0,0,0,0.5)}
.prev-img{width:100%;max-height:180px;object-fit:cover;border-radius:var(--r);margin-bottom:13px;border:1px solid rgba(255,255,255,0.3)}

/* REVEAL */
.reveal{border-radius:var(--r);padding:18px;margin-bottom:13px;animation:fu 0.5s ease forwards;background:rgba(255,255,255,0.18);backdrop-filter:blur(36px) saturate(2);-webkit-backdrop-filter:blur(36px) saturate(2);border:1px solid rgba(255,255,255,0.45);box-shadow:0 16px 48px rgba(0,0,0,0.15),inset 0 1px 0 rgba(255,255,255,0.55)}
@keyframes fu{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
.rh{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px}
.rh h3{font-size:17px;font-weight:400;line-height:1.3;color:#000}
.rh p{font-size:12px;color:rgba(0,0,0,0.5);margin-top:2px}
.badge{background:rgba(200,150,30,0.14);color:rgba(140,90,0,0.9);font-size:11px;font-weight:500;padding:3px 11px;border-radius:20px;white-space:nowrap;border:1px solid rgba(200,150,30,0.3);backdrop-filter:blur(10px)}
.rgrid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px}
.rf{background:rgba(255,255,255,0.2);border-radius:var(--rs);padding:10px 12px;border:1px solid rgba(255,255,255,0.3);backdrop-filter:blur(10px);box-shadow:inset 0 1px 0 rgba(255,255,255,0.3)}
.rl{font-size:10px;color:rgba(0,0,0,0.4);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:3px}
.rv{font-size:14px;font-weight:400;color:#000}
.rv.gold{color:rgba(130,80,0,0.9)}
.el{font-size:10px;color:rgba(0,0,0,0.38);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:8px}
.erow{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:6px}
.ei{width:100%;padding:9px 11px;background:rgba(255,255,255,0.25);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.4);border-radius:var(--rs);color:#000;font-size:13px;font-family:'DM Sans',sans-serif;transition:all 0.2s}
.ei:focus{outline:none;border-color:rgba(255,255,255,0.7);background:rgba(255,255,255,0.38)}
.ei::placeholder{color:rgba(0,0,0,0.28)}
.add-btn{width:100%;padding:12px;background:rgba(0,0,0,0.5);border:1px solid rgba(0,0,0,0.15);border-radius:var(--rs);color:#fff;font-size:14px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;margin-top:5px;transition:all 0.2s;letter-spacing:0.02em}
.add-btn:hover{background:rgba(0,0,0,0.65)}
.add-btn:disabled{opacity:0.4;cursor:not-allowed}

/* SUCCESS */
.success{text-align:center;padding:42px 18px;animation:fu 0.4s ease forwards}
.sc{width:62px;height:62px;border-radius:50%;background:rgba(80,200,100,0.16);border:1px solid rgba(80,200,100,0.35);backdrop-filter:blur(10px);display:flex;align-items:center;justify-content:center;margin:0 auto 14px;animation:pi 0.45s cubic-bezier(0.34,1.56,0.64,1) forwards;box-shadow:0 0 24px rgba(80,200,100,0.18)}
@keyframes pi{from{transform:scale(0)}to{transform:scale(1)}}
.success h2{font-family:'Bebas Neue',sans-serif;font-size:36px;letter-spacing:0px;color:#000;margin-bottom:4px}
.success .sub{font-size:13px;color:rgba(0,0,0,0.5);margin-bottom:18px}
.si{background:rgba(255,255,255,0.18);border:1px solid rgba(255,255,255,0.32);border-radius:var(--rs);padding:12px 15px;text-align:left;margin-bottom:16px;backdrop-filter:blur(10px)}
.si h4{font-size:14px;font-weight:400;color:#000}
.si span{font-size:13px;color:rgba(130,80,0,0.9)}
.act-btns{display:flex;gap:8px;justify-content:center}
.ob{padding:8px 16px;font-size:13px;border:1px solid rgba(0,0,0,0.18);border-radius:var(--rs);background:rgba(255,255,255,0.2);backdrop-filter:blur(10px);color:rgba(0,0,0,0.7);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all 0.15s}
.ob:hover{background:rgba(255,255,255,0.35);color:#000}

/* COLLECTION */
.ch{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.ch h2{font-family:'Bebas Neue',sans-serif;font-size:30px;letter-spacing:0px;color:#000}
.ic{font-size:12px;color:rgba(0,0,0,0.5);background:rgba(255,255,255,0.2);backdrop-filter:blur(10px);padding:3px 11px;border-radius:20px;border:1px solid rgba(255,255,255,0.3)}
.cgrid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
.cc{background:rgba(255,255,255,0.16);backdrop-filter:blur(24px) saturate(1.8);-webkit-backdrop-filter:blur(24px) saturate(1.8);border:1px solid rgba(255,255,255,0.32);border-radius:var(--r);overflow:hidden;cursor:pointer;transition:all 0.2s;box-shadow:0 4px 20px rgba(0,0,0,0.1),inset 0 1px 0 rgba(255,255,255,0.35)}
.cc:hover{border-color:rgba(255,255,255,0.55);transform:translateY(-2px);box-shadow:0 8px 28px rgba(0,0,0,0.15)}
.ci{width:100%;height:106px;background:rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;font-size:36px;border-bottom:1px solid rgba(255,255,255,0.18)}
.cb{padding:10px 11px}
.cn{font-size:13px;font-weight:400;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:1px;color:#000}
.cc-cat{font-size:11px;color:rgba(0,0,0,0.42);margin-bottom:6px}
.cv{font-size:14px;font-weight:400;color:rgba(130,80,0,0.9)}
.cg{font-size:11px;color:rgba(0,0,0,0.4);margin-top:1px}
.empty{text-align:center;padding:52px 18px;color:rgba(0,0,0,0.5)}
.empty h3{font-family:'Bebas Neue',sans-serif;font-size:26px;color:#000;margin-bottom:6px;letter-spacing:0}
.empty p{font-size:13px;line-height:1.6}

/* DASHBOARD */
.dh{margin-bottom:16px}
.dh h2{font-family:'Bebas Neue',sans-serif;font-size:30px;color:#000;letter-spacing:0;margin-bottom:1px}
.dh p{font-size:13px;color:rgba(0,0,0,0.5)}
.sgrid{display:grid;grid-template-columns:repeat(2,1fr);gap:9px;margin-bottom:20px}
.scard{background:rgba(255,255,255,0.16);backdrop-filter:blur(24px) saturate(1.8);border:1px solid rgba(255,255,255,0.32);border-radius:var(--r);padding:14px;box-shadow:0 4px 18px rgba(0,0,0,0.09),inset 0 1px 0 rgba(255,255,255,0.35)}
.sl{font-size:10px;color:rgba(0,0,0,0.4);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:5px}
.sv{font-family:'Bebas Neue',sans-serif;font-size:28px;letter-spacing:0;color:#000}
.ss{font-size:11px;color:rgba(30,120,50,0.9);margin-top:2px}
.stl{font-size:10px;color:rgba(0,0,0,0.38);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:10px}
.bi{display:flex;justify-content:space-between;align-items:center;padding:11px 13px;background:rgba(255,255,255,0.14);backdrop-filter:blur(18px);border:1px solid rgba(255,255,255,0.25);border-radius:var(--rs);margin-bottom:7px;box-shadow:inset 0 1px 0 rgba(255,255,255,0.25)}
.bin{font-size:13px;font-weight:400;color:#000}
.bic{font-size:11px;color:rgba(0,0,0,0.4);margin-top:1px}
.big{font-size:13px;font-weight:400;color:rgba(130,80,0,0.9);text-align:right}
.biv{font-size:11px;color:rgba(0,0,0,0.4);text-align:right}

/* PROFILE */
.info-card{background:rgba(255,255,255,0.14);backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,0.28);border-radius:var(--r);padding:14px;margin-bottom:10px;box-shadow:inset 0 1px 0 rgba(255,255,255,0.28)}
.il{font-size:10px;color:rgba(0,0,0,0.38);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:4px}
.iv{font-size:14px;font-weight:400;color:#000}
input[type="file"]{display:none}
</style>
</head>
<body>
<div class="bg" id="bg"></div>
<div class="bg-overlay"></div>

<!-- LOADING -->
<div id="loading">
  <div class="logo-big">ARCHIVE</div>
  <div class="logo-sub-sm">AI Collector Platform</div>
  <div class="lbar"><div class="lfill"></div></div>
</div>

<!-- LOGIN -->
<div id="login" class="auth hidden">
  <div class="auth-card">
    <div class="auth-logo"><h1>ARCHIVE</h1><p>AI Collector Platform</p></div>
    <div class="auth-box">
      <h2>Welcome back</h2>
      <p class="sub">Sign in to your collection</p>
      <div id="le" class="err hidden"></div>
      <div class="field"><label>Email</label><input type="email" id="le-email" placeholder="you@example.com"></div>
      <div class="field"><label>Password</label><input type="password" id="le-pw" placeholder="••••••••" onkeydown="if(event.key==='Enter')handleLogin()"></div>
      <button class="btn-p" onclick="handleLogin()">Sign in</button>
      <div class="divider">or</div>
      <button class="btn-o" onclick="handleDemo()">Continue in demo mode</button>
    </div>
    <div class="switch">No account? <a onclick="showAuth('signup')">Create one free</a></div>
  </div>
</div>

<!-- SIGNUP -->
<div id="signup" class="auth hidden">
  <div class="auth-card">
    <div class="auth-logo"><h1>ARCHIVE</h1><p>AI Collector Platform</p></div>
    <div class="auth-box">
      <h2>Create your account</h2>
      <p class="sub">Start building your collection</p>
      <div id="se" class="err hidden"></div>
      <div class="field"><label>Your name</label><input type="text" id="se-name" placeholder="Mark"></div>
      <div class="field"><label>Email</label><input type="email" id="se-email" placeholder="you@example.com"></div>
      <div class="field"><label>Password</label><input type="password" id="se-pw" placeholder="Min. 8 characters" onkeydown="if(event.key==='Enter')handleSignup()"></div>
      <button class="btn-p" onclick="handleSignup()">Create account</button>
    </div>
    <div class="switch">Have an account? <a onclick="showAuth('login')">Sign in</a></div>
  </div>
</div>

<!-- APP -->
<div id="app" class="app">
  <div class="topbar">
    <div class="topbar-logo">ARCHIVE</div>
    <div class="topbar-right">
      <div class="av" id="av">?</div>
      <button class="signout" onclick="signOut()">Sign out</button>
    </div>
  </div>
  <div class="content">
    <!-- ADD VIEW -->
    <div class="view active" id="view-add">
      <div class="ai-badge" id="ai-badge" style="display:none">✦ Real AI scanning active — GPT-4o Vision connected</div>
      <div id="s-upload">
        <div class="upzone" id="upzone" onclick="document.getElementById('fi').click()">
          <div class="up-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 4v12M9 7l3-3 3 3" stroke="rgba(0,0,0,0.5)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M4 17v2h16v-2" stroke="rgba(0,0,0,0.5)" stroke-width="1.6" stroke-linecap="round"/></svg>
          </div>
          <h3>Take a photo or upload</h3>
          <p>Works on phone camera · AI identifies in seconds</p>
        </div>
        <input type="file" id="fi" accept="image/*" capture="environment" onchange="handleFile(this.files[0])">
        <div class="demo-row">
          <p>Try a demo scan</p>
          <div class="demo-btns">
            <button class="db" onclick="demoScan(0)">Pokemon card</button>
            <button class="db" onclick="demoScan(1)">Jordan sneaker</button>
            <button class="db" onclick="demoScan(2)">Rolex watch</button>
            <button class="db" onclick="demoScan(3)">Sports card</button>
          </div>
        </div>
      </div>
      <div id="s-analyzing" class="hidden">
        <img id="prev" class="prev-img hidden">
        <div class="analyzing">
          <div class="pw"><div class="pr"></div><div class="pd"></div></div>
          <h3 id="atxt">AI is identifying your item...</h3>
          <p>Checking category, condition &amp; market value</p>
        </div>
      </div>
      <div id="s-reveal" class="hidden">
        <div class="reveal">
          <div class="rh"><div><h3 id="rn">—</h3><p id="rs">—</p></div><span class="badge" id="rb">Nice find!</span></div>
          <div class="rgrid">
            <div class="rf"><div class="rl">Condition</div><div class="rv" id="rc">—</div></div>
            <div class="rf"><div class="rl">Market value</div><div class="rv gold" id="rv">—</div></div>
            <div class="rf"><div class="rl">Category</div><div class="rv" id="rcat">—</div></div>
            <div class="rf"><div class="rl">AI confidence</div><div class="rv" id="rco">—</div></div>
          </div>
          <div class="el">Review &amp; edit</div>
          <div class="erow"><input class="ei" id="en" placeholder="Item name"><input class="ei" id="ep" type="number" placeholder="What you paid ($)"></div>
          <div class="erow"><input class="ei" id="eno" placeholder="Notes, serial #, edition..."><input class="ei" id="ed" type="date"></div>
          <button class="add-btn" id="addbtn" onclick="confirmAdd()">Add to my collection</button>
        </div>
      </div>
      <div id="s-success" class="hidden">
        <div class="success">
          <div class="sc"><svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M5 12l5 5L19 7" stroke="rgba(40,160,60,0.9)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
          <h2>ADDED TO ARCHIVE</h2>
          <p class="sub" id="subok">Saved to your collection.</p>
          <div class="si"><h4 id="sn">—</h4><span id="sv">—</span></div>
          <div class="act-btns">
            <button class="ob" onclick="resetAdd()">Add another</button>
            <button class="ob" onclick="showView('collection')">View collection</button>
          </div>
        </div>
      </div>
    </div>
    <!-- COLLECTION VIEW -->
    <div class="view" id="view-collection">
      <div class="ch"><h2>MY COLLECTION</h2><span class="ic" id="ic">0 items</span></div>
      <div class="cgrid" id="cgrid"></div>
    </div>
    <!-- DASHBOARD VIEW -->
    <div class="view" id="view-dashboard">
      <div class="dh"><h2>DASHBOARD</h2><p>Collection at a glance</p></div>
      <div class="sgrid">
        <div class="scard"><div class="sl">Total value</div><div class="sv" id="dv">$0</div><div class="ss" id="dgl">—</div></div>
        <div class="scard"><div class="sl">Items</div><div class="sv" id="dc">0</div><div class="ss" id="dcl">—</div></div>
      </div>
      <div class="stl">Best performers</div>
      <div id="blist"></div>
    </div>
    <!-- PROFILE VIEW -->
    <div class="view" id="view-profile">
      <div class="dh"><h2>PROFILE</h2></div>
      <div class="info-card"><div class="il">Signed in as</div><div class="iv" id="pe">—</div></div>
      <div class="info-card"><div class="il">AI Status</div><div class="iv" id="ai-status-text">Demo mode active</div></div>
      <button class="btn-p" style="margin-top:8px" onclick="signOut()">Sign out</button>
    </div>
  </div>
  <div class="bottom-nav">
    <button class="bn active" id="bn-add" onclick="showView('add')">
      <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M12 8v8M8 12h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>Add
    </button>
    <button class="bn" id="bn-collection" onclick="showView('collection')">
      <svg viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5"/></svg>Collection
    </button>
    <button class="bn" id="bn-dashboard" onclick="showView('dashboard')">
      <svg viewBox="0 0 24 24" fill="none"><path d="M3 18V8l9-5 9 5v10" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><rect x="8" y="12" width="8" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/></svg>Dashboard
    </button>
    <button class="bn" id="bn-profile" onclick="showView('profile')">
      <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>Profile
    </button>
  </div>
</div>

<script>
const OPENAI_KEY = typeof __OPENAI_KEY__ !== 'undefined' ? __OPENAI_KEY__ : '';
const DEMOS=[
  {name:"1999 Charizard 1st Ed. Holo",sub:"Base Set #4 · Pokémon TCG",cat:"Trading card",cond:"Near mint",val:9800,paid:6000,conf:"97%",emoji:"🃏"},
  {name:"Air Jordan 1 Retro OG Chicago",sub:"2015 · Size 10",cat:"Sneaker",cond:"Very good",val:4200,paid:220,conf:"94%",emoji:"👟"},
  {name:"Rolex Submariner Date 126610LN",sub:"2021 · Full kit",cat:"Watch",cond:"Mint",val:11500,paid:10500,conf:"99%",emoji:"⌚"},
  {name:"1952 Topps Mickey Mantle #311",sub:"PSA 3 · Centered well",cat:"Sports card",cond:"Good",val:1950,paid:1200,conf:"96%",emoji:"⚾"}
];
let user=null,coll=[],cur=null,dIdx=0;
function hide(id){document.getElementById(id).classList.add('hidden')}
function show(id){document.getElementById(id).classList.remove('hidden')}
window.addEventListener('load',()=>{
  document.getElementById('bg').style.setProperty('--bgimg',`data:image/jpeg;base64,`);
  document.getElementById('bg').style.backgroundImage=`data:image/jpeg;base64,`;
  setTimeout(()=>{
    hide('loading');
    const s=localStorage.getItem('arc_user');
    if(s){user=JSON.parse(s);loadColl();launchApp();}
    else showAuth('login');
  },1600);
});
function showAuth(s){['login','signup'].forEach(x=>hide(x));show(s);}
function handleLogin(){
  const email=document.getElementById('le-email').value.trim();
  const pw=document.getElementById('le-pw').value;
  hide('le');
  if(!email||!pw){const e=document.getElementById('le');e.textContent='Please enter email and password.';e.classList.remove('hidden');return;}
  user={id:'u_'+btoa(email).replace(/=/g,''),email,name:email.split('@')[0],created:'April 2026'};
  localStorage.setItem('arc_user',JSON.stringify(user));loadColl();launchApp();
}
function handleSignup(){
  const name=document.getElementById('se-name').value.trim();
  const email=document.getElementById('se-email').value.trim();
  const pw=document.getElementById('se-pw').value;
  hide('se');
  if(!name||!email||!pw){const e=document.getElementById('se');e.textContent='Please fill in all fields.';e.classList.remove('hidden');return;}
  if(pw.length<8){const e=document.getElementById('se');e.textContent='Password must be at least 8 characters.';e.classList.remove('hidden');return;}
  user={id:'u_'+btoa(email).replace(/=/g,''),email,name,created:'April 2026'};
  localStorage.setItem('arc_user',JSON.stringify(user));loadColl();launchApp();
}
function handleDemo(){
  user={id:'demo',email:'demo@archive.app',name:'Demo',created:'April 2026'};
  localStorage.setItem('arc_user',JSON.stringify(user));loadColl();launchApp();
}
function signOut(){user=null;coll=[];localStorage.removeItem('arc_user');document.getElementById('app').style.display='none';showAuth('login');}
function launchApp(){
  ['login','signup'].forEach(x=>hide(x));
  document.getElementById('app').style.display='flex';
  document.getElementById('av').textContent=(user.name||'?')[0].toUpperCase();
  document.getElementById('pe').textContent=user.email||'Demo user';
  if(OPENAI_KEY){document.getElementById('ai-badge').style.display='flex';document.getElementById('ai-status-text').textContent='GPT-4o Vision connected';}
  updateStats();
}
function loadColl(){const k='arc_coll_'+(user?.id||'demo');const s=localStorage.getItem(k);coll=s?JSON.parse(s):[];}
function saveColl(){localStorage.setItem('arc_coll_'+(user?.id||'demo'),JSON.stringify(coll));}
function handleFile(file){
  if(!file)return;
  const reader=new FileReader();
  reader.onload=e=>{const img=document.getElementById('prev');img.src=e.target.result;img.classList.remove('hidden');};
  reader.readAsDataURL(file);
  setState('analyzing');
  document.getElementById('atxt').textContent='AI is identifying your item...';
  if(OPENAI_KEY){identifyGPT(file);}
  else{setTimeout(()=>{showReveal(DEMOS[dIdx%DEMOS.length]);dIdx++;},2200);}
}
function demoScan(i){dIdx=i;document.getElementById('prev').classList.add('hidden');setState('analyzing');document.getElementById('atxt').textContent='Loading demo item...';setTimeout(()=>showReveal(DEMOS[i%DEMOS.length]),1800);}
async function identifyGPT(file){
  try{
    const b64=await new Promise(r=>{const fr=new FileReader();fr.onload=()=>r(fr.result.split(',')[1]);fr.readAsDataURL(file);});
    const res=await fetch('https://api.openai.com/v1/chat/completions',{method:'POST',headers:{'Authorization':`Bearer ${OPENAI_KEY}`,'Content-Type':'application/json'},body:JSON.stringify({model:'gpt-4o',max_tokens:400,messages:[{role:'user',content:[{type:'image_url',image_url:{url:`data:image/jpeg;base64,${b64}`}},{type:'text',text:`You are an expert collectibles appraiser. Identify this item. Return ONLY valid JSON with no markdown:\n{"name":"full item name","sub":"year, edition, key details","cat":"Trading Card or Sneaker or Watch or Sports Card or Coin or Other","cond":"Mint or Near Mint or Very Good or Good or Fair or Poor","val":estimated_usd_number,"conf":"confidence like 94%"}\nIf unsure, return best guess with low confidence.`}]}]})});
    const d=await res.json();
    if(d.error){showReveal({name:'Could not identify',sub:'Try a clearer photo',cat:'Other',cond:'Unknown',val:0,conf:'0%',emoji:'❓'});return;}
    const txt=d.choices[0].message.content.replace(/```json|```/g,'').trim();
    const item=JSON.parse(txt);item.paid=0;item.emoji='📷';showReveal(item);
  }catch(e){showReveal({name:'Could not identify',sub:'Try a clearer photo',cat:'Other',cond:'Unknown',val:0,conf:'0%',emoji:'❓'});}
}
function showReveal(item){
  cur=item;
  document.getElementById('rn').textContent=item.name;document.getElementById('rs').textContent=item.sub||'';
  document.getElementById('rc').textContent=item.cond;document.getElementById('rv').textContent=item.val>0?'$'+Number(item.val).toLocaleString():'Unknown';
  document.getElementById('rcat').textContent=item.cat;document.getElementById('rco').textContent=item.conf;
  document.getElementById('rb').style.display=item.val>=100?'inline-block':'none';
  document.getElementById('en').value=item.name;document.getElementById('ep').value='';document.getElementById('eno').value=item.sub||'';
  document.getElementById('ed').value=new Date().toISOString().split('T')[0];setState('reveal');
}
async function confirmAdd(){
  if(!cur)return;const btn=document.getElementById('addbtn');btn.disabled=true;btn.textContent='Saving...';
  const name=document.getElementById('en').value||cur.name;const paid=parseFloat(document.getElementById('ep').value)||0;const notes=document.getElementById('eno').value;
  const newItem={...cur,name,paid,notes,id:Date.now(),addedAt:new Date().toISOString()};
  coll.push(newItem);saveColl();updateStats();
  document.getElementById('sn').textContent=name;document.getElementById('sv').textContent=cur.val>0?'Market value: $'+Number(cur.val).toLocaleString():'Added to collection';
  document.getElementById('subok').textContent='Your collection now has '+coll.length+' item'+(coll.length!==1?'s':'')+'.';
  setState('success');btn.disabled=false;btn.textContent='Add to my collection';
}
function resetAdd(){cur=null;document.getElementById('prev').classList.add('hidden');document.getElementById('fi').value='';setState('upload');}
function setState(s){['upload','analyzing','reveal','success'].forEach(id=>{const el=document.getElementById('s-'+id);id===s?el.classList.remove('hidden'):el.classList.add('hidden');});}
function showView(v){document.querySelectorAll('.view').forEach(el=>el.classList.remove('active'));document.querySelectorAll('.bn').forEach(el=>el.classList.remove('active'));document.getElementById('view-'+v).classList.add('active');const bn=document.getElementById('bn-'+v);if(bn)bn.classList.add('active');if(v==='collection')renderColl();if(v==='dashboard')renderDash();}
function renderColl(){
  const g=document.getElementById('cgrid');document.getElementById('ic').textContent=coll.length+' item'+(coll.length!==1?'s':'');
  if(!coll.length){g.innerHTML='<div class="empty" style="grid-column:1/-1"><h3>NOTHING HERE YET</h3><p>Tap Add and photograph something you own.</p></div>';return;}
  g.innerHTML='';[...coll].reverse().forEach(item=>{const gain=item.paid>0?Math.round(((item.val-item.paid)/item.paid)*100):null;const c=document.createElement('div');c.className='cc';c.innerHTML=`<div class="ci">${item.emoji||'📦'}</div><div class="cb"><div class="cn">${item.name}</div><div class="cc-cat">${item.cat}</div><div class="cv">${item.val>0?'$'+Number(item.val).toLocaleString():'—'}</div><div class="cg">${gain!==null?(gain>=0?'+':'')+gain+'% vs. paid':'Value tracked'}</div></div>`;g.appendChild(c);});
}
function renderDash(){
  const total=coll.reduce((s,i)=>s+Number(i.val),0);const paid=coll.reduce((s,i)=>s+Number(i.paid||0),0);const gain=total-paid;const cats=[...new Set(coll.map(i=>i.cat))];
  document.getElementById('dv').textContent='$'+total.toLocaleString();document.getElementById('dc').textContent=coll.length;
  document.getElementById('dgl').textContent=gain>=0?'+$'+gain.toLocaleString()+' total gain':'-$'+Math.abs(gain).toLocaleString();document.getElementById('dcl').textContent=cats.length+' categor'+(cats.length!==1?'ies':'y');
  const sorted=[...coll].filter(i=>i.paid>0).sort((a,b)=>((b.val-b.paid)/b.paid)-((a.val-a.paid)/a.paid));
  const list=document.getElementById('blist');
  if(!sorted.length){list.innerHTML='<div style="font-size:13px;color:rgba(0,0,0,0.5);padding:12px 0">Add purchase prices when adding items to see best performers.</div>';return;}
  list.innerHTML='';sorted.slice(0,5).forEach(item=>{const g=Math.round(((item.val-item.paid)/item.paid)*100);const el=document.createElement('div');el.className='bi';el.innerHTML=`<div><div class="bin">${item.name}</div><div class="bic">${item.cat}</div></div><div><div class="big">${g>=0?'+':''}${g}%</div><div class="biv">$${Number(item.val).toLocaleString()}</div></div>`;list.appendChild(el);});
}
function updateStats(){const total=coll.reduce((s,i)=>s+Number(i.val),0);document.getElementById('dv').textContent='$'+total.toLocaleString();document.getElementById('dc').textContent=coll.length;}
const uz=document.getElementById('upzone');
uz.addEventListener('dragover',e=>{e.preventDefault();uz.classList.add('drag');});
uz.addEventListener('dragleave',()=>uz.classList.remove('drag'));
uz.addEventListener('drop',e=>{e.preventDefault();uz.classList.remove('drag');if(e.dataTransfer.files[0])handleFile(e.dataTransfer.files[0]);});
</script>

</body>
</html>
